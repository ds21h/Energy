<Window x:Class="Energy.frmLoad"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Energy"
        mc:Ignorable="d"
        Title="Meterstanden laden" Height="200" Width="480" ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Label Content="Meterstanden laden" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="24"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" Grid.Row="1" Grid.ColumnSpan="2">
            <Label Content="Startdatum" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center"/>
            <DatePicker x:Name="dpStart" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center" local:DatePickerHelper.Watermark="Start datum" SelectedDateChanged="dpStart_SelectedDateChanged" />
            <Label Content="Einddatum" HorizontalAlignment="Left" Margin="20,0,0,0" VerticalAlignment="Center"/>
            <DatePicker x:Name="dpEnd" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center" local:DatePickerHelper.Watermark="Eind datum" SelectedDateChanged="dpEnd_SelectedDateChanged" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,10" Grid.Row="2">
            <Button Content="Annuleren" HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center" Width="100" Click="ButtonCancel_Click"/>
            <Button Content="Laden" HorizontalAlignment="Right" Margin="0,0,0,0" VerticalAlignment="Center" Width="100" Click="ButtonLoad_Click"/>
        </StackPanel>
    </Grid>
</Window>
