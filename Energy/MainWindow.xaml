<Window x:Class="Energy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:local="clr-namespace:Energy"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="1074" Closing="Window_Closing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <MenuItem Header="_Bestand">
                <MenuItem x:Name="mnuLoad" Header="_Laad Meterstanden" Click="mnuLoad_Click"/>
                <MenuItem x:Name="mnuExport" Header="_Exporteer" Click="mnuExport_Click"/>
            </MenuItem>
        </Menu>

        <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="0">
            <Button x:Name="btnList" Grid.Column="1" Content="List" HorizontalAlignment="Left" Margin="0,0,0,0" VerticalAlignment="Top" Click="btnList_Click"/>
            <Button x:Name="btnGraph" Grid.Column="1" Content="Graph" HorizontalAlignment="Left" Margin="0,0,0,0" VerticalAlignment="Top" Click="btnGraph_Click"/>
        </StackPanel>
        <Frame x:Name="frView" NavigationUIVisibility="Hidden" Grid.Row="1" Grid.Column="1"/>
    </Grid>
</Window>
